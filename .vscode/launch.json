{
  "version": "0.2.0",
  "configurations": [
    {
      // Launches electron-vite in dev mode. VS Code attaches to the main process
      // automatically. Breakpoints and `debugger;` statements in src/main/** work.
      "name": "Debug Main Process",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "${workspaceRoot}/node_modules/.bin/electron-vite",
      "windows": {
        "runtimeExecutable": "${workspaceRoot}/node_modules/.bin/electron-vite.cmd"
      },
      "runtimeArgs": ["dev", "--sourcemap"],
      "env": {
        "REMOTE_DEBUGGING_PORT": "9222"
      },
      "outputCapture": "std",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      // Attach to the renderer (React) process. Open the app first via
      // "Debug Main Process" or `npm run dev`, then start this.
      // Breakpoints and `debugger;` in src/renderer/src/** work.
      "name": "Debug Renderer Process",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/src/renderer/src",
      "timeout": 60000,
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/@fs/*": "/*",
        "/@renderer/*": "${workspaceFolder}/src/renderer/src/*"
      },
      "presentation": {
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug All",
      "configurations": ["Debug Main Process", "Debug Renderer Process"],
      "presentation": {
        "order": 1
      }
    }
  ]
}
